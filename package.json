{
  "name": "@trancendos/cornelius-ai",
  "version": "1.0.0",
  "description": "Master AI Orchestrator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:cve": "node scripts/security/cve-check.mjs",
    "security:nminusone": "node scripts/security/nminusone-check.mjs",
    "security:all": "pnpm run security:cve && pnpm run security:nminusone",
    "governance:audit": "node scripts/governance/audit-repositories.mjs --owner Trancendos --output docs/reports/repository-security-audit.json"
  },
  "author": "Trancendos",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@trancendos/shared-core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@trancendos/shared-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "semver": "^7.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
