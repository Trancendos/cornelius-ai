{
  "name": "@trancendos/cornelius-ai",
  "version": "1.0.0",
  "description": "Master AI Orchestrator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude dist/**",
    "test:watch": "vitest --exclude dist/**",
    "security:policy": "node scripts/security/policy-check.mjs",
    "security:cve": "node scripts/security/cve-check.mjs",
    "security:nminusone": "node scripts/security/nminusone-check.mjs",
    "security:all": "pnpm run security:policy && pnpm run security:cve && pnpm run security:nminusone",
    "security:sbom": "pnpm dlx @cyclonedx/cyclonedx-npm --output-file sbom.cdx.json --output-format JSON",
    "governance:audit": "node scripts/governance/audit-repositories.mjs --owner Trancendos --output docs/reports/repository-security-audit.json",
    "governance:regulatory": "node scripts/governance/regulatory-readiness-check.mjs --report docs/reports/repository-security-audit.json --output docs/regulatory-readiness-status.md",
    "governance:gap-analysis": "node scripts/governance/generate-final-gap-analysis.mjs --owner Trancendos --report docs/reports/repository-security-audit.json --output docs/final-gap-analysis.md",
    "governance:initiate": "node scripts/governance/initiate-remediation.mjs --owner Trancendos --report docs/reports/repository-security-audit.json --output docs/remediation-initiation-summary.md"
  },
  "author": "Trancendos",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@trancendos/shared-core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@trancendos/shared-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "semver": "^7.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
