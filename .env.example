# Cornelius-AI Environment Configuration
# Copy this file to .env and fill in the values

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY=1h

# ── Infinity Portal Backend ───────────────────────────────────────────────────
INFINITY_PORTAL_URL=http://localhost:8000
INFINITY_PORTAL_API_KEY=

# ── LLM Provider (for intent classification) ─────────────────────────────────
# Options: openai | anthropic | local | none
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Agent Mesh ────────────────────────────────────────────────────────────────
AGENT_HEARTBEAT_INTERVAL_MS=30000
CONSENSUS_TIMEOUT_MS=10000
MAX_ORCHESTRATION_HISTORY=1000

# ── Nexus ACO Routing ─────────────────────────────────────────────────────────
ACO_EVAPORATION_RATE=0.1
ACO_REINFORCEMENT_FACTOR=0.3
ACO_PHASE2_THRESHOLD=10

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_ENABLED=true
MCP_SERVER_NAME=cornelius-ai

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: trace | debug | info | warn | error | fatal
LOG_LEVEL=info